{
  "expo": {
    "name": "Chef de Casa",
    "slug": "chef-da-casa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F9F5F0"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.chefdacasa.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F9F5F0"
      },
      "package": "com.chefdacasa.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png",
      "name": "Chef de Casa",
      "shortName": "Chef",
      "description": "Gere receitas com os ingredientes que você tem em casa usando IA",
      "themeColor": "#E8622A",
      "backgroundColor": "#F9F5F0",
      "lang": "pt-BR"
    },
    "scheme": "chefdacasa",
    "plugins": [
      "expo-router"
    ]
  }
}
